{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Taskbit",
  "version": "0.1.0",
  "identifier": "com.taskbit.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @taskbit/web dev",
    "beforeBuildCommand": "pnpm --filter @taskbit/web build",
    "devUrl": "http://localhost:6900/app",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Taskbit",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
