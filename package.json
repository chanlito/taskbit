{
  "name": "taskbit",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev --filter=@taskbit/web --filter=@taskbit/api",
    "dev:web": "pnpm --filter @taskbit/web dev",
    "dev:api": "pnpm --filter @taskbit/api dev",
    "dev:desktop": "pnpm --filter @taskbit/desktop dev",
    "build:desktop:install": "pnpm --filter @taskbit/desktop build:install",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "check": "turbo run check",
    "precommit": "pnpm format && pnpm lint",
    "prepush": "pnpm typecheck && pnpm test && pnpm build",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.6.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm precommit",
    "pre-push": "pnpm prepush"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
